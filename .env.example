# ============================================
# ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to Git!

# ============================================
# SUPABASE (Primary Database) - REQUIRED
# ============================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================
# RESEND (Email Service) - OPTIONAL
# ============================================
# Used for sending password reset emails and automated reports
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# ============================================
# CRON JOBS - REQUIRED FOR AUTOMATED REPORTS
# ============================================
# Secret token to secure cron endpoints
# Generate a random string: openssl rand -base64 32
CRON_SECRET=your_random_cron_secret_here

# ============================================
# APPLICATION URL - OPTIONAL
# ============================================
# Used in email templates for dashboard links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# NOTES
# ============================================
# 1. Get Supabase credentials from: https://app.supabase.com/project/_/settings/api
# 2. Keep SUPABASE_SERVICE_ROLE_KEY secret - it has full database access
# 3. Resend is optional - forgot password will work without it (logs temp password instead)

# ============================================
# 21ST SDK (AI Agent) - OPTIONAL
# ============================================
# Used for AI-powered inventory assistant
# Get your API key from: https://platform.21st.dev
API_KEY_21ST=your_21st_sdk_api_key_here
